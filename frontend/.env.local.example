NEXT_PUBLIC_API_URL=http://localhost:8080

# "enabled" liga o MSW (Mock Service Worker), que simula os endpoints de
# Reviews, Listas e Dashboard enquanto o backend deles não existe (Fases 3-5).
# Endpoints já reais (auth, books) NÃO são mockados, passam direto pro backend.
# Quando o backend real estiver pronto, é só trocar pra "disabled" (ou remover a linha).
NEXT_PUBLIC_API_MOCKING=enabled
